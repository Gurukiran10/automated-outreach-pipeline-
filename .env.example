# ─── Ocean.io ─────────────────────────────────────────────────────────────────
# Get your token at: https://app.ocean.io → Settings → API tokens
# Auth is sent as a QUERY PARAMETER (?apiToken=...), NOT an Authorization header.
OCEAN_API_KEY=your_ocean_api_token_here
OCEAN_BASE_URL=https://api.ocean.io
OCEAN_LOOKALIKE_LIMIT=10

# ─── Prospeo ──────────────────────────────────────────────────────────────────
# Get your key at: https://app.prospeo.io/api
# Auth header: X-KEY: YOUR_KEY
PROSPEO_API_KEY=your_prospeo_api_key_here
PROSPEO_BASE_URL=https://api.prospeo.io
PROSPEO_CONTACTS_PER_DOMAIN=25
PROSPEO_MAX_PAGES=4
PROSPEO_ONLY_VERIFIED_EMAIL=true

# ─── EazyReach ────────────────────────────────────────────────────────────────
# TODO: Contact EazyReach support to confirm base URL and auth scheme.
# Auth header (assumed): Authorization: Bearer YOUR_KEY
EAZYREACH_API_KEY=your_eazyreach_api_key_here
EAZYREACH_BASE_URL=https://api.eazyreach.io/v1

# ─── Brevo (Sendinblue) ───────────────────────────────────────────────────────
# Get your key at: https://app.brevo.com → SMTP & API → API Keys
# Auth header: api-key: YOUR_KEY
# IMPORTANT: BREVO_SENDER_EMAIL must be a verified sender in your Brevo account.
# Verify at: app.brevo.com → Senders & IP → Senders
BREVO_API_KEY=your_brevo_api_key_here
BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_NAME=Gurukiran
BREVO_SENDER_EMAIL=gurukiran.s@seedlinglabs.com

# ─── HTTP / Retry ─────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=2.0
RETRY_BACKOFF_MULTIPLIER=2.0

# ─── Output / Logging ─────────────────────────────────────────────────────────
DATA_DIR=data
LOG_DIR=logs
LOG_LEVEL=INFO
